# WaccApp környezeti változók mintafájl
# Ezt a fájlt másold át .env néven, majd a saját fejlesztői adataiddal töltsd ki.
# Valódi token, jelszó vagy API-kulcs nem kerülhet a digitális mellékletbe.

# Alkalmazás
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
TZ=Europe/Budapest
APP_TZ=Europe/Budapest
PRIVACY_VERSION=v1

# Adatbázis
# Alapértelmezett helyi adatbázis a forráskód mappájában:
DB_PATH=whatsapp_messages.db
# A mellékletben szereplő tesztadatbázis használatához például:
# DB_PATH=../../03_adatbazis/whatsapp_messages_teszt.db

# Admin, munkamenet és regisztráció
SESSION_SECRET=change-this-session-secret
ADMIN_SETUP_TOKEN=change-this-admin-setup-token
ALLOW_SELF_SIGNUP=false
DEFAULT_ROLE_ON_SIGNUP=viewer
ALLOWED_EMAIL_DOMAINS=

# Meta / WhatsApp Business API
VERIFY_TOKEN=change-this-verify-token
ACCESS_TOKEN=replace-with-meta-access-token
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-with-waba-id
PHONE_NUMBER_ID=replace-with-phone-number-id
GRAPH_API_VERSION=v19.0
APP_SECRET=replace-with-meta-app-secret-if-used

# E-mail küldés regisztrációhoz / visszaigazoláshoz
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=replace-with-smtp-password
MAIL_FROM="WaccApp" <no-reply@example.com>

# Opcionális futási beállítások
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info
AUDIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
